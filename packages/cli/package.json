{
  "name": "@kirkelabs/open-agent-access-cli",
  "version": "0.1.0",
  "description": "CLI for Open Agent Access for Algorand.",
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "package.json"
  ],
  "bin": {
    "oaa": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p ../../tsconfig.base.json"
  },
  "dependencies": {
    "@kirkelabs/open-agent-access-compliance": "workspace:*",
    "@kirkelabs/open-agent-access-conformance": "workspace:*",
    "@kirkelabs/open-agent-access-core": "workspace:*",
    "@kirkelabs/open-agent-access-enterprise": "workspace:*",
    "@kirkelabs/open-agent-access-evidence": "workspace:*",
    "@kirkelabs/open-agent-access-identity": "workspace:*",
    "@kirkelabs/open-agent-access-incident": "workspace:*",
    "@kirkelabs/open-agent-access-mandates": "workspace:*",
    "@kirkelabs/open-agent-access-policy-as-code": "workspace:*",
    "@kirkelabs/open-agent-access-payments-algorand-x402": "workspace:*"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts"
}
