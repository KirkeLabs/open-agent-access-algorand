{
  "name": "@open-agent-access/cli",
  "version": "0.1.0",
  "description": "CLI for Open Agent Access for Algorand.",
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "package.json"
  ],
  "bin": {
    "oaa": "dist/packages/cli/src/index.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p ../../tsconfig.base.json"
  },
  "dependencies": {
    "@open-agent-access/conformance": "workspace:*",
    "@open-agent-access/core": "workspace:*",
    "@open-agent-access/enterprise": "workspace:*",
    "@open-agent-access/evidence": "workspace:*",
    "@open-agent-access/identity": "workspace:*",
    "@open-agent-access/mandates": "workspace:*",
    "@open-agent-access/payments-algorand-x402": "workspace:*"
  }
}
