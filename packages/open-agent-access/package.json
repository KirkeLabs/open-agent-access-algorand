{
  "name": "@kirkelabs/open-agent-access",
  "version": "0.1.2",
  "description": "One-command installer and CLI front door for Open Agent Access.",
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "package.json"
  ],
  "bin": {
    "open-agent-access": "dist/index.js",
    "agent-passport": "dist/index.js",
    "oaa": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p ../../tsconfig.base.json"
  },
  "dependencies": {
    "@kirkelabs/open-agent-access-cli": "workspace:*"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts"
}
