{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node", "vitest/globals"],
    "paths": {
      "@open-agent-access/core": ["./packages/core/src/index.ts"],
      "@open-agent-access/hono": ["./packages/hono/src/index.ts"],
      "@open-agent-access/payments-algorand-x402": ["./packages/payments-algorand-x402/src/index.ts"],
      "@open-agent-access/mandates": ["./packages/mandates/src/index.ts"],
      "@open-agent-access/mcp": ["./packages/mcp/src/index.ts"]
    }
  },
  "include": [
    "packages/**/*.ts",
    "examples/**/*.ts",
    "scripts/**/*.ts",
    "vitest.config.ts"
  ]
}
